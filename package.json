{
  "name": "@vrcalphabet/web-fs",
  "description": "TypeScriptで書かれたFile System Access APIを簡単に操作するためのラッパーライブラリ",
  "publishConfig": {
    "access": "public"
  },
  "version": "2.0.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "format": "prettier --write \"src/**/*.ts\" --log-level warn",
    "docs": "npx typedoc"
  },
  "homepage": "https://github.com/vrcalphabet/web-fs",
  "bugs": {
    "url": "https://github.com/vrcalphabet/web-fs/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vrcalphabet/web-fs.git"
  },
  "keywords": [
    "filesystem",
    "filesystemhandle",
    "filesystemfilehandle",
    "filesystemdirectoryhandle",
    "fsa",
    "glob"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/md5": "^2.3.6",
    "@types/node": "^25.5.0",
    "@types/wicg-file-system-access": "^2023.10.7",
    "typedoc": "^0.28.18",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-dts": "^4.5.4"
  },
  "dependencies": {
    "idb-keyval": "^6.2.2",
    "md5": "^2.3.0",
    "web-fs-glob": "^1.0.4"
  }
}
